{
  "name": "salesforce-dev-mcp",
  "version": "1.0.0",
  "description": "Salesforce Developer Model Context Protocol (MCP) Server",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "salesforce",
    "mcp",
    "model-context-protocol",
    "typescript",
    "jsforce"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.6.0",
    "dotenv": "^16.4.5",
    "execa": "^9.1.0",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "jsforce": "^3.1.2",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.2.5",
    "simple-git": "^3.24.0",
    "xmlbuilder2": "^3.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
